n\"\n                viewBox=\"0 0 16 16\"\u003E\n                \u003Cpath fill-rule=\"evenodd\"\n                    d=\"M8 1a.5.5 0 0 1 .5.5v11.793l3.146-3.147a.5.5 0 0 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-4-4a.5.5 0 0 1 .708-.708L7.5 13.293V1.5A.5.5 0 0 1 8 1z\" /\u003E\n            \u003C/svg\u003E\n            \u003Cspan id=\"networkDownload\"\u003E0 B/s\u003C/span\u003E\n        \u003C/div\u003E\n        \u003Cdiv class=\"network-stats-upload\"\u003E\n            \u003Csvg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"currentColor\" class=\"bi bi-arrow-up\"\n                viewBox=\"0 0 16 16\"\u003E\n                \u003Cpath fill-rule=\"evenodd\"\n                    d=\"M8 15a.5.5 0 0 0 .5-.5V2.707l3.146 3.147a.5.5 0 0 0 .708-.708l-4-4a.5.5 0 0 0-.708 0l-4 4a.5.5 0 1 0 .708.708L7.5 2.707V14.5a.5.5 0 0 0 .5.5z\" /\u003E\n            \u003C/svg\u003E\n            \u003Cspan id=\"networkUpload\"\u003E0 B/s\u003C/span\u003E\n        \u003C/div\u003E\n    \u003C/div\u003E\n    \u003Cdiv class=\"button-hotspot\"\u003E\n        \u003Cbutton type=\"button\" id=\"btnHotSpot\"\u003E\n            \u003Csvg id=\"iconHotSpotOff\" xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" fill=\"currentColor\"\n                class=\"bi bi-toggle-off\" viewBox=\"0 0 16 16\"\u003E\n                \u003Cpath\n                    d=\"M11 4a4 4 0 0 1 0 8H8a4.992 4.992 0 0 0 2-4 4.992 4.992 0 0 0-2-4h3zm-6 8a4 4 0 1 1 0-8 4 4 0 0 1 0 8zM0 8a5 5 0 0 0 5 5h6a5 5 0 0 0 0-10H5a5 5 0 0 0-5 5z\" /\u003E\n            \u003C/svg\u003E\n            \u003Csvg id=\"iconHotSpotOn\" xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" fill=\"currentColor\"\n                class=\"bi bi-toggle-on\" viewBox=\"0 0 16 16\"\u003E\n                \u003Cpath d=\"M5 3a5 5 0 0 0 0 10h6a5 5 0 0 0 0-10H5zm6 9a4 4 0 1 1 0-8 4 4 0 0 1 0 8z\" /\u003E\n            \u003C/svg\u003E\n            \u003Cspan\u003EHOTSPOT\u003C/span\u003E\n        \u003C/button\u003E\n    \u003C/div\u003E\n    \u003Cdiv class=\"button-airplane\"\u003E\n        \u003Cbutton type=\"button\" id=\"btnAirplane\"\u003E\n            \u003Csvg id=\"iconAirplaneOff\" xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" fill=\"currentColor\"\n                class=\"bi bi-toggle-off\" viewBox=\"0 0 16 16\"\u003E\n                \u003Cpath\n                    d=\"M11 4a4 4 0 0 1 0 8H8a4.992 4.992 0 0 0 2-4 4.992 4.992 0 0 0-2-4h3zm-6 8a4 4 0 1 1 0-8 4 4 0 0 1 0 8zM0 8a5 5 0 0 0 5 5h6a5 5 0 0 0 0-10H5a5 5 0 0 0-5 5z\" /\u003E\n            \u003C/svg\u003E\n            \u003Csvg id=\"iconAirplaneOn\" xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" fill=\"currentColor\"\n                class=\"bi bi-toggle-on\" viewBox=\"0 0 16 16\"\u003E\n                \u003Cpath d=\"M5 3a5 5 0 0 0 0 10h6a5 5 0 0 0 0-10H5zm6 9a4 4 0 1 1 0-8 4 4 0 0 1 0 8z\" /\u003E\n            \u003C/svg\u003E\n            \u003Cspan\u003EMODO AVIAO\u003C/span\u003E\n        \u003C/button\u003E\n    \u003C/div\u003E\n    \u003Cscript\u003E\n        const btnStartCheckUser = document.querySelector('#btnStartCheckUser');\n        const btnOpenSpeedTest = document.querySelector('#btnOpenSpeedTest');\n        const configVersion = document.getElementById('version');\n        const btnHotSpot = document.querySelector(\"#btnHotSpot\");\n        const iconHotSpotOff = document.querySelector(\"#iconHotSpotOff\");\n        const iconHotSpotOn = document.querySelector(\"#iconHotSpotOn\");\n        const btnAirplane = document.querySelector(\"#btnAirplane\");\n        const iconAirplaneOff = document.querySelector(\"#iconAirplaneOff\");\n        const iconAirplaneOn = document.querySelector(\"#iconAirplaneOn\")\n        const networkDownloadElement = document.querySelector('#networkDownload');\n        const networkUploadElement = document.querySelector('#networkUpload');\n\n        const currentNetworkDownload = parseFloat(localStorage.getItem('networkDownload') ?? window?.DtGetNetworkDownloadBytes?.execute() ?? 0);\n        const currentNetworkUpload = parseFloat(localStorage.getItem('networkUpload') ?? window?.DtGetNetworkUploadBytes?.execute() ?? 0);\n        localStorage.setItem('networkDownload', currentNetworkDownload);\n        localStorage.setItem('networkUpload', currentNetworkUpload);\n\n        const formatBytes = bytes =\u003E {\n            const sizes = ['B/s', 'KB/s', 'MB/s', 'GB/s', 'TB/s'];\n            if (bytes === 0) return '0 B/s';\n            const i = parseInt(Math.floor(Math.log(bytes) / Math.log(1024)));\n            return (bytes / Math.pow(1024, i)).toPrecision(3) + ' ' + sizes[i];\n        };\n\n        const updateNetworkStats = () =\u003E {\n            const newNetworkDownload = window?.DtGetNetworkDownloadBytes?.execute() ?? 0;\n            const newNetworkUpload = window?.DtGetNetworkUploadBytes?.execute() ?? 0;\n\n            networkDownloadElement.innerHTML = formatBytes(newNetworkDownload - currentNetworkDownload);\n            networkUploadElement.innerHTML = formatBytes(newNetworkUpload - currentNetworkUpload);\n        };\n\n        const toggleHotSpot = () =\u003E {\n            const hotSpotStatus = window?.DtGetStatusHotSpotService?.execute() ?? 'STOPPED';\n            hotSpotStatus == 'RUNNING' ? stopHotSpot() : startHotSpot();\n        };\n\n        const startHotSpot = () =\u003E {\n            window?.DtStartHotSpotService?.execute();\n            iconHotSpotOn.style.display = 'block';\n            iconHotSpotOff.style.display = 'none';\n        };\n\n        const stopHotSpot = () =\u003E {\n            window?.DtStopHotSpotService?.execute();\n            iconHotSpotOff.style.display = 'block';\n            iconHotSpotOn.style.display = 'none';\n        };\n\n        const toggleAirplane = () =\u003E {\n            const airplaneStatus = window?.DtAirplaneState?.execute() ?? 'INCATIVE';\n            console.log(airplaneStatus);\n            airplaneStatus == 'ACTIVE' ? stopAirplane() : startAirplane();\n        };\n\n        const startAirplane = () =\u003E {\n            window?.DtAirplaneActivate?.execute();\n            iconAirplaneOn.style.display = 'block';\n            iconAirplaneOff.style.display = 'none';\n        }\n\n        const stopAirplane = () =\u003E {\n            window?.DtAirplaneDeactivate?.execute();\n            iconAirplaneOff.style.display = 'block';\n            iconAirplaneOn.style.display = 'none';\n        }\n\n        const parseResponseData = data =\u003E {\n            data = JSON.parse(data);\n            if (data.total) {\n                const total = data.total;\n                document.getElementById('total').innerHTML = String(total).padStart(2, '0');\n            }\n        };\n\n        const createConnection = () =\u003E {\n            const config = JSON.parse(window?.DtGetDefaultConfig?.execute() ?? '{}');\n            const urlCheckUser = new URL(config?.url_check_user ?? 'http://0.0.0.0:5000');\n            urlCheckUser.protocol = 'ws:';\n            return new WebSocket(urlCheckUser);\n        };\n\n        const startActions = socket =\u003E {\n            socket.send(JSON.stringify({\n                action: 'all',\n                data: {}\n            }));\n        };\n\n        const startSocket = () =\u003E {\n            const socket = createConnection();\n            socket.onopen = e =\u003E startActions(socket);\n            socket.onmessage = e =\u003E parseResponseData(e.data);\n        };\n\n        btnStartCheckUser.addEventListener('click', () =\u003E DtStartCheckUser.execute());        btnOpenSpeedTest.addEventListener('click', () =\u003E DtStartWebViewActivity.execute('https://fast.com/'));\n        btnHotSpot.addEventListener('click', toggleHotSpot);\n        btnAirplane.addEventListener('click', toggleAirplane);\n\n        const hotSpotStatus = window?.DtGetStatusHotSpotService?.execute() ?? 'STOPPED';\n        if (hotSpotStatus == 'RUNNING') {\n            iconHotSpotOff.style.display = 'none';\n            iconHotSpotOn.style.display = 'block';\n        } else {\n            iconHotSpotOn.style.display = 'none';\n            iconHotSpotOff.style.display = 'block';\n        }\n\n        const airplaneStatus = window?.DtAirplaneState?.execute() ?? 'INACTIVE';\n        if (airplaneStatus == 'ACTIVE') {\n            iconAirplaneOff.style.display = 'none';\n            iconAirplaneOn.style.display = 'block';\n        } else {\n            iconAirplaneOn.style.display = 'none';\n            iconAirplaneOff.style.display = 'block';\n        }\n\n        configVersion.innerHTML = window?.DtGetLocalConfigVersion?.execute() ?? '1.0';\n\n        updateNetworkStats();\n        startSocket();\n\n        setInterval(() =\u003E {\n            updateNetworkStats();\n            configVersion.innerHTML = window?.DtGetLocalConfigVersion?.execute() ?? '1.0';\n        }, 1000);\n    \u003C/script\u003E\n\u003C/body\u003E\n\n\u003C/html\u003E"
  },
